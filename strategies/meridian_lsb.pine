//@version=6
strategy(
    title                   = "Meridian - London Session Breakout",
    shorttitle              = "Meridian LSB",
    overlay                 = true,
    default_qty_type        = strategy.cash,
    default_qty_value       = 1000,
    currency                = currency.USD,
    initial_capital         = 10000,
    commission_type         = strategy.commission.percent,
    commission_value        = 0.01,
    slippage                = 2,
    process_orders_on_close = true)

// =============================================================================
// INPUTS
// =============================================================================

// 1 - Session Windows (all times UTC)
i_asian_start  = input.int(2,  "Asian range start (UTC hr)", minval=0, maxval=23, group="1 - Session")
i_asian_end    = input.int(7,  "Asian range end (UTC hr)",   minval=0, maxval=23, group="1 - Session")
i_london_start = input.int(8,  "Breakout window start",      minval=0, maxval=23, group="1 - Session")
i_london_end   = input.int(10, "Breakout window end",        minval=0, maxval=23, group="1 - Session")
i_cutoff_hr    = input.int(12, "Force-close hour (UTC)",     minval=0, maxval=23, group="1 - Session")

// 2 - Entry
i_buffer_pips = input.float(2.0, "Entry buffer (pips)",     minval=0.0, step=0.5, group="2 - Entry")
i_tp_mult     = input.float(1.5, "TP multiplier (x range)", minval=0.5, step=0.1, group="2 - Entry")

// 3 - Range Filter
i_min_pips = input.float(15.0, "Min range (pips)", minval=1.0,  step=1.0, group="3 - Range Filter")
i_max_pips = input.float(50.0, "Max range (pips)", minval=10.0, step=5.0, group="3 - Range Filter")

// 4 - Day Filter
i_mon = input.bool(true,  "Monday",    group="4 - Day Filter")
i_tue = input.bool(true,  "Tuesday",   group="4 - Day Filter")
i_wed = input.bool(true,  "Wednesday", group="4 - Day Filter")
i_thu = input.bool(true,  "Thursday",  group="4 - Day Filter")
i_fri = input.bool(false, "Friday",    group="4 - Day Filter")

// 5 - Risk
i_risk_pct   = input.float(1.0,  "Risk per trade (%)",     minval=0.1, maxval=10.0, step=0.1, group="5 - Risk")
i_daily_loss = input.float(3.0,  "Daily loss limit (%)",   minval=0.5, step=0.5,              group="5 - Risk")
i_consec_max = input.int(3,      "Consecutive loss limit", minval=1,   maxval=10,             group="5 - Risk")
i_max_dd     = input.float(20.0, "Hard drawdown stop (%)", minval=5.0, step=1.0,              group="5 - Risk")

// 6 - H4 Trend Filter (optional)
i_h4_filter  = input.bool(false, "Enable H4 trend filter", group="6 - H4 Trend Filter")
i_h4_ema_len = input.int(50,     "H4 EMA period",          minval=5, maxval=500, group="6 - H4 Trend Filter")

// 7 - Display
i_show_range = input.bool(true, "Show Asian range lines",   group="7 - Display")
i_show_bg    = input.bool(true, "Show session backgrounds", group="7 - Display")

// =============================================================================
// CONSTANTS
// =============================================================================
// 1 pip = 10x mintick (EURUSD mintick=0.00001, pip=0.0001)
pip = syminfo.mintick * 10

// =============================================================================
// TIME
// =============================================================================
utc_hour   = hour(time, "UTC")
utc_minute = minute(time, "UTC")
utc_dow    = dayofweek(time, "UTC")
utc_date   = year(time, "UTC") * 10000 + month(time, "UTC") * 100 + dayofmonth(time, "UTC")

in_asian  = utc_hour >= i_asian_start  and utc_hour < i_asian_end
in_london = utc_hour >= i_london_start and utc_hour < i_london_end
at_cutoff = utc_hour == i_cutoff_hr    and utc_minute == 0

day_ok = (utc_dow == dayofweek.monday    and i_mon) or
         (utc_dow == dayofweek.tuesday   and i_tue) or
         (utc_dow == dayofweek.wednesday and i_wed) or
         (utc_dow == dayofweek.thursday  and i_thu) or
         (utc_dow == dayofweek.friday    and i_fri)

// =============================================================================
// DAILY STATE -- resets each new UTC calendar day
// =============================================================================
var int   last_day         = 0
var float asian_high       = na
var float asian_low        = na
var bool  entered_today    = false
var bool  long_taken       = false
var bool  short_taken      = false
var bool  both_broken      = false
var float day_start_equity = na
var bool  blocked_daily    = false
var bool  consec_blocked   = false
var int   consec_losses    = 0
var bool  be_active        = false
var int   last_trade_count = 0

new_day = utc_date != last_day and utc_date > last_day
if new_day
    last_day         := utc_date
    asian_high       := na
    asian_low        := na
    entered_today    := false
    long_taken       := false
    short_taken      := false
    both_broken      := false
    day_start_equity := strategy.equity
    blocked_daily    := false
    consec_blocked   := false
    consec_losses    := 0

// =============================================================================
// ASIAN RANGE
// =============================================================================
if in_asian
    asian_high := na(asian_high) ? high : math.max(asian_high, high)
    asian_low  := na(asian_low)  ? low  : math.min(asian_low,  low)

range_built = not na(asian_high) and not na(asian_low)
range_pips  = range_built ? (asian_high - asian_low) / pip : na
range_valid = range_built and range_pips >= i_min_pips and range_pips <= i_max_pips

// =============================================================================
// ENTRY LEVELS
// =============================================================================
buf         = i_buffer_pips * pip
entry_long  = range_built ? asian_high + buf : na
entry_short = range_built ? asian_low  - buf : na
sl_long     = range_built ? asian_low  - buf : na
sl_short    = range_built ? asian_high + buf : na
tp_long     = range_built ? entry_long  + range_pips * pip * i_tp_mult : na
tp_short    = range_built ? entry_short - range_pips * pip * i_tp_mult : na

// =============================================================================
// H4 TREND FILTER
// =============================================================================
h4_ema     = request.security(syminfo.tickerid, "240", ta.ema(close, i_h4_ema_len))
h4_bullish = close > h4_ema
h4_bearish = close < h4_ema

// =============================================================================
// CIRCUIT BREAKERS
// =============================================================================
if not na(day_start_equity) and strategy.equity < day_start_equity * (1.0 - i_daily_loss / 100.0)
    blocked_daily := true

equity_peak  = strategy.initial_capital + math.max(strategy.max_runup, 0)
current_dd   = equity_peak > 0 ? (equity_peak - strategy.equity) / equity_peak * 100.0 : 0.0
hard_blocked = current_dd >= i_max_dd

if strategy.closedtrades > last_trade_count
    last_profit = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if last_profit < 0
        consec_losses += 1
        if consec_losses >= i_consec_max
            consec_blocked := true
    else
        consec_losses  := 0
        consec_blocked := false
    last_trade_count := strategy.closedtrades

// =============================================================================
// FALSE BREAKOUT DETECTION
// =============================================================================
if in_london and range_valid
    if close > entry_long
        long_taken := true
    if close < entry_short
        short_taken := true
    if long_taken and short_taken
        both_broken := true

// =============================================================================
// ENTRY SIGNALS
// =============================================================================
// Split into intermediate vars to avoid multi-line boolean parse errors
filters_ok = day_ok and range_valid and not both_broken and not entered_today
risk_ok    = not blocked_daily and not consec_blocked and not hard_blocked
can_trade  = filters_ok and risk_ok and strategy.position_size == 0

// Signal fires on the first bar that closes beyond the level in the London window.
// long_taken[1] is true if the level was already crossed on a prior bar -> skip.
long_signal  = can_trade and in_london and close > entry_long  and not long_taken[1]  and (not i_h4_filter or h4_bullish)
short_signal = can_trade and in_london and close < entry_short and not short_taken[1] and (not i_h4_filter or h4_bearish)

// Position size: risk i_risk_pct% of equity over stop distance.
// Most accurate for USD-quoted pairs (EURUSD, GBPUSD). Approximate for JPY pairs.
long_qty  = (strategy.equity * i_risk_pct / 100.0) / math.abs(entry_long  - sl_long)
short_qty = (strategy.equity * i_risk_pct / 100.0) / math.abs(sl_short - entry_short)

if long_signal
    strategy.entry("Long",  strategy.long,  qty=long_qty,  comment="LSB Long")
    strategy.exit("Long X", "Long",  stop=sl_long,  limit=tp_long)
    entered_today := true
    be_active     := false

if short_signal
    strategy.entry("Short", strategy.short, qty=short_qty, comment="LSB Short")
    strategy.exit("Short X", "Short", stop=sl_short, limit=tp_short)
    entered_today := true
    be_active     := false

// =============================================================================
// BREAKEVEN -- move SL to entry once price travels 1R in profit
// =============================================================================
if strategy.position_size > 0 and not be_active
    ep        = strategy.position_avg_price
    risk_dist = ep - sl_long
    if high >= ep + risk_dist
        strategy.exit("Long X", "Long", stop=ep, limit=tp_long)
        be_active := true

if strategy.position_size < 0 and not be_active
    ep        = strategy.position_avg_price
    risk_dist = sl_short - ep
    if low <= ep - risk_dist
        strategy.exit("Short X", "Short", stop=ep, limit=tp_short)
        be_active := true

if strategy.position_size == 0
    be_active := false

// =============================================================================
// FORCE CLOSE -- any trade still open at cutoff is closed
// =============================================================================
if at_cutoff and strategy.position_size != 0
    strategy.close_all(comment="12:00 Cutoff")

// =============================================================================
// VISUALS
// =============================================================================
in_manage = utc_hour >= i_london_end and utc_hour < i_cutoff_hr
bgcolor(i_show_bg and in_asian  ? color.new(color.blue,   90) : na, title="Asian session")
bgcolor(i_show_bg and in_london ? color.new(color.orange, 88) : na, title="London breakout window")
bgcolor(i_show_bg and in_manage ? color.new(color.green,  93) : na, title="Manage window")

show_lvls = i_show_range and range_built and (in_london or in_manage)
plot(show_lvls ? asian_high  : na, "Asian High",  color=color.new(color.yellow, 20), linewidth=1)
plot(show_lvls ? asian_low   : na, "Asian Low",   color=color.new(color.yellow, 20), linewidth=1)
plot(show_lvls ? entry_long  : na, "Entry Long",  color=color.new(color.lime,   35), linewidth=1, style=plot.style_circles)
plot(show_lvls ? entry_short : na, "Entry Short", color=color.new(color.red,    35), linewidth=1, style=plot.style_circles)
plot(show_lvls and range_valid ? tp_long  : na, "TP Long",  color=color.new(color.lime, 55), linewidth=1, style=plot.style_cross)
plot(show_lvls and range_valid ? tp_short : na, "TP Short", color=color.new(color.red,  55), linewidth=1, style=plot.style_cross)

// Status table
var table info = table.new(position.top_right, 2, 7, frame_color=color.new(color.gray, 60), frame_width=1, border_color=color.new(color.gray, 70), border_width=1)

f_cell(col, row, txt, clr) =>
    table.cell(info, col, row, txt, text_color=clr, text_size=size.small, bgcolor=color.new(color.black, 65))

if barstate.islast
    f_cell(0, 0, "Range",      color.gray)
    f_cell(1, 0, range_built ? str.tostring(math.round(nz(range_pips), 1)) + " pip" : "n/a", range_valid ? color.lime : color.red)
    f_cell(0, 1, "Day",        color.gray)
    f_cell(1, 1, day_ok ? "OK" : "SKIP", day_ok ? color.lime : color.red)
    f_cell(0, 2, "FalseBreak", color.gray)
    f_cell(1, 2, both_broken ? "SKIP" : "OK", both_broken ? color.red : color.lime)
    f_cell(0, 3, "Daily DD",   color.gray)
    f_cell(1, 3, blocked_daily ? "BLOCKED" : "OK", blocked_daily ? color.red : color.lime)
    f_cell(0, 4, "Consec L",   color.gray)
    f_cell(1, 4, str.tostring(consec_losses) + (consec_blocked ? " BLK" : ""), consec_blocked ? color.red : color.lime)
    f_cell(0, 5, "Drawdown",   color.gray)
    f_cell(1, 5, str.tostring(math.round(current_dd, 1)) + "%" + (hard_blocked ? " STOP" : ""), hard_blocked ? color.red : color.lime)
    f_cell(0, 6, "H4",         color.gray)
    f_cell(1, 6, not i_h4_filter ? "OFF" : h4_bullish ? "BULL" : "BEAR", not i_h4_filter ? color.gray : h4_bullish ? color.lime : color.red)
